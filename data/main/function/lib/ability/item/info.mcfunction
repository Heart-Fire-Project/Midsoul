tellraw @s[scores={item=5}] [{translate:"ms.relic.5.desc",fallback:"于当前位置与方向部署一个高效制冷模块，守卫者经过其面前时移速 -45%%"},"\n",{translate:"ms.relic.5.desc.sub",fallback:"场上至多存在 2 个同名模块，超出上限时清除先被部署的模块",color:"gray"}]
